# AMTTP Sepolia Deployment Configuration
# ========================================

# Your wallet's private key (WITHOUT 0x prefix)
# To get this:
# 1. Open MetaMask
# 2. Click the three dots next to your account
# 3. Account details > Show private key
# 4. Enter password and copy the key
PRIVATE_KEY=your_private_key_here_without_0x

# Get Sepolia ETH for gas:
# - https://sepoliafaucet.com
# - https://www.alchemy.com/faucets/ethereum-sepolia
# - https://sepolia-faucet.pk910.de (PoW faucet)

# Optional: RPC URLs (defaults are provided in hardhat.config.cjs)
# SEPOLIA_RPC_URL=https://rpc.sepolia.org
# ETHERSCAN_API_KEY=your_etherscan_api_key

# IMPORTANT SECURITY NOTES:
# - NEVER commit this file to git
# - NEVER share your private key
# - Use a dedicated testnet wallet (not your main wallet)

# AMTTP Docker Environment Configuration
# Copy this file to .env and fill in your values

# ngrok Authentication Token
# Get yours at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# MongoDB Credentials
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme

# MinIO (Object Storage) Credentials
MINIO_ROOT_USER=localtest
MINIO_ROOT_PASSWORD=localtest123

# Vault Token (for secrets management)
VAULT_TOKEN=root

# Optional: Custom domain for ngrok (paid plans only)
# NGROK_DOMAIN=your-custom-domain.ngrok.io

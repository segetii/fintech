# =============================================================================
# AMTTP Backend Services - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# UI Integrity Service Configuration
# -----------------------------------------------------------------------------
# CRITICAL: Generate a strong admin key using:
#   openssl rand -hex 32
# This key protects admin endpoints that register trusted UI hashes
INTEGRITY_ADMIN_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# URL where integrity service is accessible
# Production: https://integrity.your-domain.com
# Development: http://localhost:8008
INTEGRITY_SERVICE_URL=http://localhost:8008

# IP addresses allowed to access admin endpoints (comma-separated)
# Production: Restrict to VPN, internal IPs, or CI/CD runners
ADMIN_IPS=127.0.0.1,10.0.0.0/8

# Path to store trusted UI component hashes
TRUSTED_HASHES_PATH=./data/integrity/trusted_hashes.json

# Path to store violation logs (append-only JSONL)
VIOLATIONS_LOG_PATH=./data/integrity/violations.jsonl

# -----------------------------------------------------------------------------
# Orchestrator Service Configuration
# -----------------------------------------------------------------------------
# Enable/disable API authentication (ALWAYS true in production)
AUTH_ENABLED=true

# API key for external services to call orchestrator
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ORCHESTRATOR_API_KEY=CHANGE_ME

# Enable/disable storage layer (MongoDB, Redis, MinIO, IPFS)
USE_STORAGE_LAYER=true

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
# Connection URL for MongoDB
# Format: mongodb://[username:password@]host[:port][/database]
MONGODB_URL=mongodb://admin:changeme@localhost:27017

# Database name for AMTTP
MONGODB_DB=amttp

# Collection names (optional overrides)
MONGODB_PROFILES_COLLECTION=entity_profiles
MONGODB_DECISIONS_COLLECTION=compliance_decisions
MONGODB_AUDIT_COLLECTION=audit_log

# Connection pool settings
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=10
MONGODB_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Connection URL for Redis
# Format: redis://[username:password@]host[:port][/database]
REDIS_URL=redis://localhost:6379

# Redis database number (0-15)
REDIS_DB=0

# Key prefix for namespacing
REDIS_KEY_PREFIX=amttp:

# Connection pool settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Rate limiting configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Cache TTL (seconds)
CACHE_TTL_SHORT=300      # 5 minutes
CACHE_TTL_MEDIUM=1800    # 30 minutes
CACHE_TTL_LONG=3600      # 1 hour

# -----------------------------------------------------------------------------
# MinIO Configuration (S3-Compatible Object Storage)
# -----------------------------------------------------------------------------
# MinIO server endpoint (without http://)
MINIO_ENDPOINT=localhost:9000

# Access credentials
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Use HTTPS for MinIO connection (true in production)
MINIO_SECURE=false

# Bucket names
MINIO_KYC_BUCKET=amttp-kyc-documents
MINIO_EVIDENCE_BUCKET=amttp-compliance-evidence
MINIO_REPORTS_BUCKET=amttp-reports

# Presigned URL expiry (seconds)
MINIO_PRESIGNED_URL_EXPIRY=3600

# -----------------------------------------------------------------------------
# IPFS Configuration (Immutable Audit Trail)
# -----------------------------------------------------------------------------
# IPFS API endpoint
IPFS_API_URL=http://localhost:5001

# IPFS Gateway for retrieving files (optional)
IPFS_GATEWAY_URL=http://localhost:8080

# Timeout for IPFS operations (seconds)
IPFS_TIMEOUT=30

# Pin uploaded files to ensure persistence
IPFS_AUTO_PIN=true

# -----------------------------------------------------------------------------
# Compliance Services Configuration
# -----------------------------------------------------------------------------
# Base URLs for compliance microservices
SANCTIONS_SERVICE_URL=http://localhost:8004
MONITORING_SERVICE_URL=http://localhost:8005
GEO_RISK_SERVICE_URL=http://localhost:8006

# Service timeouts (seconds)
SERVICE_TIMEOUT=10
SERVICE_RETRY_ATTEMPTS=3

# -----------------------------------------------------------------------------
# zkNAF Configuration (Zero-Knowledge Network Activity Filter)
# -----------------------------------------------------------------------------
# zkNAF service endpoint
ZKNAF_SERVICE_URL=http://localhost:8003

# Risk threshold for zkNAF (0.0 - 1.0)
ZKNAF_RISK_THRESHOLD=0.7

# Enable/disable zkNAF integration
ZKNAF_ENABLED=true

# -----------------------------------------------------------------------------
# Risk Router Configuration
# -----------------------------------------------------------------------------
# Risk Router service endpoint
RISK_ROUTER_URL=http://localhost:8002

# Risk scoring thresholds
RISK_THRESHOLD_LOW=0.3
RISK_THRESHOLD_MEDIUM=0.6
RISK_THRESHOLD_HIGH=0.8

# Enable/disable risk router
RISK_ROUTER_ENABLED=true

# -----------------------------------------------------------------------------
# Security & Encryption
# -----------------------------------------------------------------------------
# JWT secret for token signing
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# JWT expiry (seconds)
JWT_EXPIRY=3600

# Encryption key for sensitive data (32 bytes hex)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# CORS allowed origins (comma-separated)
# Production: Use actual domain(s), NO wildcards!
CORS_ORIGINS=http://localhost:3000,https://app.your-domain.com

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable structured JSON logging (recommended for production)
LOG_JSON=true

# Log file path (leave empty to log to stdout only)
LOG_FILE_PATH=./logs/orchestrator.log

# Log rotation settings
LOG_MAX_BYTES=10485760  # 10 MB
LOG_BACKUP_COUNT=5

# Enable request/response logging (can be verbose)
LOG_HTTP_REQUESTS=false

# -----------------------------------------------------------------------------
# Alerting & Monitoring (Optional)
# -----------------------------------------------------------------------------
# Slack webhook for critical alerts
SLACK_WEBHOOK_URL=

# Email alerts configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@your-domain.com
ALERT_EMAIL_TO=security@your-domain.com

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Application environment (development, staging, production)
APP_ENV=development

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable specific features
FEATURE_BATCH_TRANSFERS=true
FEATURE_CROSS_CHAIN=true
FEATURE_DISPUTE_RESOLUTION=true
FEATURE_MACHINE_LEARNING=true

# -----------------------------------------------------------------------------
# External API Keys (Optional)
# -----------------------------------------------------------------------------
# Chainalysis API (for enhanced AML screening)
CHAINALYSIS_API_KEY=
CHAINALYSIS_API_URL=https://api.chainalysis.com

# Elliptic API (for transaction monitoring)
ELLIPTIC_API_KEY=
ELLIPTIC_API_URL=https://api.elliptic.co

# TRM Labs API (for wallet screening)
TRM_API_KEY=
TRM_API_URL=https://api.trmlabs.com

# -----------------------------------------------------------------------------
# Development/Testing Settings
# -----------------------------------------------------------------------------
# Enable development mode (more verbose logging, relaxed security)
DEV_MODE=true

# Enable test mode (use mock data, skip external API calls)
TEST_MODE=false

# Mock delay for simulating network latency (milliseconds)
MOCK_DELAY=0

# =============================================================================
# Quick Start Checklist
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Generate keys:
#    - INTEGRITY_ADMIN_KEY: openssl rand -hex 32
#    - ORCHESTRATOR_API_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
#    - JWT_SECRET: openssl rand -base64 32
#    - ENCRYPTION_KEY: openssl rand -hex 32
# 3. Update MongoDB/Redis/MinIO/IPFS URLs with your actual endpoints
# 4. Set CORS_ORIGINS to your frontend domain(s)
# 5. Set AUTH_ENABLED=true and DEV_MODE=false in production
# 6. Review and configure alerting (Slack, email, Sentry)
# 7. NEVER commit .env to git!
# =============================================================================

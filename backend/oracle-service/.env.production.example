# =============================================================================
# AMTTP Oracle Service - Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to version control!

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# -----------------------------------------------------------------------------
# Blockchain RPC (use a reliable provider)
# -----------------------------------------------------------------------------
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Or Infura:
# RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Contract Addresses (update after mainnet deployment)
AMTTP_ADDRESS=0x_MAINNET_CONTRACT_ADDRESS

# -----------------------------------------------------------------------------
# HSM Configuration - AWS KMS (Option 1)
# -----------------------------------------------------------------------------
# AWS credentials should come from IAM role, not env vars in production
AWS_REGION=eu-west-1

# Oracle signing keys (create with ECC_SECG_P256K1)
ORACLE_KMS_KEY_1=arn:aws:kms:eu-west-1:123456789012:key/your-key-id-1
ORACLE_KMS_KEY_2=arn:aws:kms:eu-west-1:123456789012:key/your-key-id-2
ORACLE_KMS_KEY_3=arn:aws:kms:eu-west-1:123456789012:key/your-key-id-3

# Multi-oracle threshold (2-of-3 recommended minimum)
ORACLE_THRESHOLD=2

# -----------------------------------------------------------------------------
# HSM Configuration - HashiCorp Vault (Option 2)
# Uncomment if using Vault instead of AWS KMS
# -----------------------------------------------------------------------------
# VAULT_ADDR=https://vault.internal.amttp.io:8200
# VAULT_ROLE_ID=your-approle-role-id
# VAULT_SECRET_ID=your-approle-secret-id
# VAULT_TRANSIT_MOUNT=transit
# ORACLE_VAULT_KEY_1=amttp-oracle-1
# ORACLE_VAULT_KEY_2=amttp-oracle-2
# ORACLE_VAULT_KEY_3=amttp-oracle-3

# -----------------------------------------------------------------------------
# KYC Provider
# -----------------------------------------------------------------------------
KYC_PROVIDER=sumsub

# Sumsub Production Credentials
SUMSUB_APP_TOKEN=prd:YOUR_PRODUCTION_APP_TOKEN
SUMSUB_SECRET_KEY=YOUR_PRODUCTION_SECRET_KEY
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_SANDBOX=0

# Yoti (optional alternative)
# YOTI_SDK_ID=
# YOTI_PRIVATE_KEY_BASE64=

# -----------------------------------------------------------------------------
# ML Risk Engine
# -----------------------------------------------------------------------------
RISK_ENGINE_URL=https://ml.internal.amttp.io:8000/score
RISK_ENGINE_API_KEY=your-internal-api-key

# Chainalysis (requires license)
# CHAINALYSIS_API_KEY=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://amttp-prod:YOUR_SECURE_PASSWORD@mongo-cluster.internal:27017/amttp?authSource=admin&replicaSet=rs0&tls=true

# Redis (for rate limiting / caching)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis-cluster.internal:6379

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# JWT signing (use a strong random value)
JWT_SECRET=your-256-bit-random-secret-here

# API rate limits
RATE_LIMIT_PER_ADDRESS=10
RATE_LIMIT_GLOBAL=100

# Signature validity window (seconds)
SIGNATURE_VALIDITY_SECONDS=300

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
DATADOG_API_KEY=your-datadog-api-key

# Alert webhooks
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
ALERT_PAGERDUTY_KEY=your-pagerduty-routing-key

# -----------------------------------------------------------------------------
# FCA Compliance
# -----------------------------------------------------------------------------
FCA_FIRM_REFERENCE=FRN-XXXXXX
MLRO_EMAIL=mlro@amttp.io
SAR_SUBMISSION_ENDPOINT=https://nca-portal/submit

# -----------------------------------------------------------------------------
# Cross-Chain (LayerZero)
# -----------------------------------------------------------------------------
# LayerZero endpoint addresses per chain
LZ_ENDPOINT_MAINNET=0x66A71Dcef29A0fFBDBE3c6a460a3B5BC225Cd675
LZ_ENDPOINT_POLYGON=0x3c2269811836af69497E5F486A85D7316753cf62
LZ_ENDPOINT_ARBITRUM=0x3c2269811836af69497E5F486A85D7316753cf62

{
  "detectors_to_run": [
    "reentrancy-eth",
    "reentrancy-no-eth",
    "reentrancy-benign",
    "reentrancy-events",
    "uninitialized-state",
    "uninitialized-storage",
    "uninitialized-local",
    "arbitrary-send-erc20",
    "arbitrary-send-erc20-permit",
    "arbitrary-send-eth",
    "controlled-delegatecall",
    "delegatecall-loop",
    "suicidal",
    "shadowing-state",
    "shadowing-abstract",
    "shadowing-local",
    "locked-ether",
    "unchecked-transfer",
    "unchecked-lowlevel",
    "unchecked-send",
    "missing-zero-check",
    "tx-origin",
    "msg-value-loop",
    "divide-before-multiply",
    "weak-prng",
    "incorrect-equality",
    "costly-loop",
    "reentrancy-unlimited-gas",
    "unprotected-upgrade",
    "encode-packed-collision",
    "assembly",
    "boolean-equal",
    "deprecated-standards",
    "erc20-interface",
    "erc721-interface",
    "incorrect-modifier",
    "mapping-deletion",
    "naming-convention",
    "pragma",
    "redundant-statements",
    "similar-names",
    "solc-version",
    "unused-return",
    "unused-state",
    "unimplemented-functions",
    "variable-scope"
  ],
  "exclude_informational": false,
  "exclude_low": false,
  "exclude_medium": false,
  "exclude_high": false,
  "exclude_optimization": true,
  "filter_paths": [
    "node_modules",
    "lib",
    "test",
    "mocks"
  ],
  "solc_remaps": [
    "@openzeppelin/=node_modules/@openzeppelin/",
    "@layerzero-labs/=node_modules/@layerzero-labs/",
    "@kleros/=node_modules/@kleros/"
  ],
  "solc_args": "--optimize --optimize-runs 200",
  "json": "audit/slither-report.json",
  "sarif": "audit/slither-report.sarif",
  "markdown_root": "https://github.com/segetii/fintech/blob/main/",
  "show_ignored_findings": false,
  "fail_on": "high",
  "printers_to_run": [
    "contract-summary",
    "function-summary",
    "call-graph",
    "inheritance-graph",
    "modifiers",
    "require",
    "variable-order"
  ]
}

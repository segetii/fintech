{
  "name": "@amttp/client-sdk",
  "version": "1.0.0",
  "description": "AMTTP Client SDK - Regulatory-compliant transaction protocol with Stacked Ensemble ML risk scoring",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "amttp",
    "blockchain",
    "compliance",
    "aml",
    "kyc",
    "risk-scoring",
    "dqn",
    "ethereum",
    "web3",
    "regtech"
  ],
  "author": "AMTTP Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/segetii/fintech"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ethers": "^6.9.0",
    "eventemitter3": "^5.0.1"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
